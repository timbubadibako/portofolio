// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id           String      @id @default(uuid())
  name         String
  description  String?
  techStack    Json        // Menyimpan array stack: ["Flutter", "Dart", "Supabase"]
  architecture String      // Misal: "Clean Architecture", "MVC"
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  tasks        Task[]
  blueprints   Blueprint[]
}

model Task {
  id          String    @id @default(uuid())
  projectId   String
  title       String
  status      String    // "TODO", "IN_PROGRESS", "DONE"
  commitMsg   String?   // Auto-generated commit message pattern
  completedAt DateTime?
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Blueprint {
  id         String   @id @default(uuid())
  projectId  String
  schemaJson Json     // Menyimpan skema database mentah objek baru
  aiRules    String[] // Aturan coding khusus untuk dibaca Gemini
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
